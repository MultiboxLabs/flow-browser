[Desktop Entry]
Name=Flow
Comment=A modern privacy-focused browser with a minimalistic design
GenericName=Web Browser
Exec=run.sh %u
Icon=dev.iamevan.flow
Type=Application
StartupNotify=true
StartupWMClass=Flow
Categories=Network;WebBrowser;
MimeType=text/html;text/xml;application/xhtml+xml;application/pdf;x-scheme-handler/http;x-scheme-handler/https;
Actions=new-window;new-private-window;

[Desktop Action new-window]
Name=New Window
Exec=run.sh --new-window %u

[Desktop Action new-private-window]
Name=New Private Window
Exec=run.sh --incognito %u
