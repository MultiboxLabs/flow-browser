{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.tsx",
    "src/preload/*.d.ts",
    "src/shared/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "types": ["@types/chrome"],
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./src/renderer/src/*"
      ],
      "~/*": ["./src/shared/*"]
    }
  }
}
